# GitHub PAT for the public Projects page (avoids API rate limiting)
# Create at: https://github.com/settings/tokens/new?scopes=public_repo
GITHUB_TOKEN=ghp_your-token-here

# ─── Editor (selambuarada.com/write) ───────────────────────────────────────

# One-time bootstrap token for new devices.
# Visit https://selambuarada.com/write?setup=<EDITOR_SECRET> once per device;
# the server drops a long-lived signed cookie and you never see this again.
# Generate with:  openssl rand -hex 32
EDITOR_SECRET=replace-with-32-byte-hex

# HMAC key for signing the session cookie. Rotating this logs out all devices.
# Generate with:  openssl rand -hex 32
EDITOR_COOKIE_SECRET=replace-with-32-byte-hex

# Fine-grained PAT for committing posts to GitHub from the editor's save endpoint.
# Scope: Contents: read & write on the selambuarada.com repo only.
# Create at: https://github.com/settings/personal-access-tokens/new
GITHUB_WRITE_TOKEN=github_pat_your-token-here
