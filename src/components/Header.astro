---
import { getLangFromUrl, useTranslations, localePath, contactPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pathname = Astro.url.pathname;

const navLinks = [
  { path: '/about', label: t('nav.about') },
  { path: '/blog', label: t('nav.blog') },
  { path: '/projects', label: t('nav.projects') },
  { path: '/films', label: t('nav.films') },
  { path: contactPath(lang), label: t('nav.contact') },
];

function isActive(linkPath: string): boolean {
  const href = localePath(lang, linkPath);
  if (href === '/' || href === `/${lang}`) return pathname === href;
  return pathname.startsWith(href);
}
---

<header class="w-full border-b border-[var(--c-border)]">
  <div class="mx-auto max-w-2xl px-4 py-4 flex items-center justify-between">
    <a href={localePath(lang, '/')} class="font-bold text-[var(--c-text)]">
      Semih Mutlu
    </a>

    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(({ path, label }) => (
        <a
          href={localePath(lang, path)}
          class:list={[
            'text-sm hover:underline underline-offset-4',
            isActive(path) ? 'text-[var(--c-text)]' : 'text-[var(--c-text-faint)]',
          ]}
        >
          {label}
        </a>
      ))}
      <LanguageSwitcher />
    </div>

    <button
      id="menu-toggle"
      class="md:hidden text-[var(--c-text-faint)]"
      aria-label={t('nav.menu')}
    >
      <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--c-border)]">
    <div class="mx-auto max-w-2xl px-4 py-3 flex flex-col gap-2">
      {navLinks.map(({ path, label }) => (
        <a
          href={localePath(lang, path)}
          class="text-sm text-[var(--c-text-faint)] hover:text-[var(--c-text)] py-1"
        >
          {label}
        </a>
      ))}
      <div class="pt-2 border-t border-[var(--c-border)]">
        <LanguageSwitcher />
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
