---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import profileImg from '../assets/profile.png';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredPosts = posts.slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('tr-TR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title="Semih Mutlu" description="Okur, yazar, bozar, yapar. Teknoloji, bilim ve hayat üzerine yazılar.">

  <!-- Hero Section -->
  <section class="py-10 md:py-14 border-b border-[var(--c-border)]">
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8">
      <Image
        src={profileImg}
        alt="Semih Mutlu"
        width={180}
        height={180}
        class="w-[180px] h-[180px] object-cover flex-shrink-0"
      />

      <div class="text-center sm:text-left">
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--c-text)]">
          Semih Mutlu
        </h1>
        <p class="mt-2 text-[var(--c-text-soft)] italic">
          okur, yazar, bozar, yapar.
        </p>
        <p class="mt-3 text-[var(--c-text-soft)] leading-relaxed max-w-lg">
          Teknoloji, bilim ve hayat üzerine düşüncelerimi paylaştığım kişisel blog.
          Yazılım geliştirici, meraklı okur, ara sıra filmci.
        </p>
      </div>
    </div>
  </section>

  <!-- Two Column Layout -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 py-8 md:py-12">

    <!-- Main: Post List -->
    <div class="lg:col-span-2">
      <h2 class="text-xl font-bold text-[var(--c-text)] mb-6">Son Yazılar</h2>

      {posts.length === 0 && (
        <p class="text-[var(--c-text-faint)]">Henüz yazı yok.</p>
      )}

      <div class="flex flex-col divide-y divide-[var(--c-border)]">
        {posts.map((post) => (
          <article class="py-6 first:pt-0">
            <time class="text-sm text-[var(--c-text-faint)]" datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
            <h3 class="mt-1 text-lg md:text-xl font-bold text-[var(--c-text)]">
              <a href={`/blog/${post.id}`} class="hover:underline underline-offset-4">
                {post.data.title}
              </a>
            </h3>
            <p class="mt-2 text-[var(--c-text-soft)] text-sm leading-relaxed line-clamp-2">
              {post.data.description}
            </p>
          </article>
        ))}
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-8">
      <div class="border border-[var(--c-border)] p-5">
        <h3 class="text-base font-bold text-[var(--c-text)] mb-3">Hakkımda</h3>
        <p class="text-sm text-[var(--c-text-soft)] leading-relaxed">
          Yazılım geliştirici, meraklı okur, filmci. Teknoloji ve bilim arasında
          köprü kurmaya çalışıyor, arada hayata dair notlar düşüyorum.
        </p>
        <a href="/about" class="inline-block mt-3 text-sm text-[var(--c-text)] font-medium hover:underline underline-offset-4">
          Devamını oku &rarr;
        </a>
      </div>

      <div class="border border-[var(--c-border)] p-5">
        <h3 class="text-base font-bold text-[var(--c-text)] mb-3">Öne Çıkanlar</h3>
        <ul class="space-y-2">
          {featuredPosts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="text-sm text-[var(--c-text-soft)] hover:underline underline-offset-4 leading-snug block"
              >
                {post.data.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  </div>

</BaseLayout>
