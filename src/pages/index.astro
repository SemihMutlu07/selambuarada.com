---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import profileImg from '../assets/profile.png';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [
  { slug: 'tumu', label: 'Tümü' },
  { slug: 'teknoloji', label: 'Teknoloji' },
  { slug: 'bilim', label: 'Bilim' },
  { slug: 'hayat', label: 'Hayat' },
  { slug: 'notlar', label: 'Notlar' },
];

const featuredPosts = posts.slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('tr-TR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title="Semih Mutlu" description="Okur, yazar, bozar, yapar. Teknoloji, bilim ve hayat üzerine yazılar.">

  <!-- Hero Section -->
  <section class="py-10 md:py-14 border-b border-[#e0e0e0]">
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8">
      <!-- Profile photo -->
      <Image
        src={profileImg}
        alt="Semih Mutlu"
        width={180}
        height={180}
        class="w-[180px] h-[180px] object-cover flex-shrink-0"
      />

      <div class="text-center sm:text-left">
        <h1 class="font-serif text-3xl md:text-4xl font-bold tracking-tight text-[#1a1a1a]">
          Semih Mutlu
        </h1>
        <p class="mt-2 text-[#666] italic">
          okur, yazar, bozar, yapar.
        </p>
        <p class="mt-3 text-[#444] leading-relaxed max-w-lg">
          Teknoloji, bilim ve hayat üzerine düşüncelerimi paylaştığım kişisel blog.
          Yazılım geliştirici, meraklı okur, ara sıra filmci.
        </p>

        <!-- Social links -->
        <div class="mt-5 flex items-center gap-4 justify-center sm:justify-start">
          <a href="https://github.com/SemihMutlu07" target="_blank" rel="noopener noreferrer" class="text-[#666] hover:text-[#1a1a1a] transition-colors" aria-label="GitHub">
