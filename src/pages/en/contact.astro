---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { person, socialLinks } from '../../lib/seo';

const t = useTranslations('en');
---
<BaseLayout title={t('contact.title')} description={t('contact.description')}>

  <h1 class="text-2xl font-bold">{t('contact.title')}</h1>

  <p class="mt-4 text-[var(--c-text-soft)]">
    {t('contact.intro')}
  </p>

  <button
    id="copy-email"
    data-email={person.email}
    class="mt-3 text-[var(--c-text)] underline underline-offset-4 cursor-pointer hover:no-underline"
  >
    {person.email}
  </button>
  <span id="copy-toast" class="ml-2 text-sm text-[var(--c-text-faint)] opacity-0 transition-opacity duration-300">
    {t('contact.copied')}
  </span>

  <div class="mt-8">
    <h2 class="font-bold mb-3">{t('contact.findMe')}</h2>
    <ul class="space-y-1">
      {socialLinks.map(({ href, label }) => (
        <li>
          <a href={href} target="_blank" rel="noopener noreferrer" class="text-[var(--c-text-faint)] hover:text-[var(--c-text)] hover:underline underline-offset-4">
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>

</BaseLayout>

<script>
  const btn = document.getElementById('copy-email')!;
  const toast = document.getElementById('copy-toast')!;

  btn.addEventListener('click', async () => {
    await navigator.clipboard.writeText(btn.dataset.email!);
    toast.style.opacity = '1';
    setTimeout(() => { toast.style.opacity = '0'; }, 2000);
  });
</script>
