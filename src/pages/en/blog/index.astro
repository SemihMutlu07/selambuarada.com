---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, getDateLocale, localePath, getSlugFromId } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/translations';

const lang: Lang = 'en';
const t = useTranslations(lang);

const allPosts = await getCollection('blog', ({ data }) => {
  return data.lang === lang && (import.meta.env.PROD ? !data.draft : true);
});
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateLocale = getDateLocale(lang);
function formatDate(date: Date): string {
  return date.toLocaleDateString(dateLocale, { year: 'numeric', month: 'short' });
}
---

<BaseLayout title={t('blog.title')} description={t('blog.description')}>

  <h1 class="text-2xl font-bold">{t('blog.title')}</h1>

  {posts.length === 0 ? (
    <p class="mt-6 text-[var(--c-text-faint)]">{t('blog.empty')}</p>
  ) : (
    <ul class="mt-8 list-none p-0">
      {posts.map((post, i) => {
        const slug = getSlugFromId(post.id);
        return (
          <li class:list={['border-t border-[var(--c-border)]', i === posts.length - 1 && 'border-b']}>
            <a href={localePath(lang, `/blog/${slug}`)} class="block py-4 group">
              <div class="flex items-baseline justify-between gap-4">
                <span class="text-[var(--c-text)] group-hover:underline underline-offset-4">
                  {post.data.title}
                </span>
                <time datetime={post.data.date.toISOString()} class="text-sm text-[var(--c-text-faint)] shrink-0">
                  {formatDate(post.data.date)}
                </time>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  )}

</BaseLayout>
