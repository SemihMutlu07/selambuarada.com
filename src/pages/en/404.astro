---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localePath } from '../../i18n/utils';

const t = useTranslations('en');
---
<BaseLayout title={t('404.title')} description={t('404.description')}>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <h1 class="text-6xl font-bold text-[var(--c-text)]">404</h1>
    <p class="mt-4 text-lg text-[var(--c-text-soft)]">{t('404.message')}</p>
    <a
      href={localePath('en', '/')}
      class="mt-8 text-sm text-[var(--c-text-faint)] hover:underline underline-offset-4"
    >
      {t('404.backHome')}
    </a>
  </div>
</BaseLayout>
