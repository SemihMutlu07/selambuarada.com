---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { personJsonLd, websiteJsonLd } from '../../lib/seo';

const t = useTranslations('en');
---

<BaseLayout title={t('home.title')} description={t('home.description')}>

  <script type="application/ld+json" set:html={personJsonLd} />
  <script type="application/ld+json" set:html={websiteJsonLd} />

  <h1 class="text-2xl font-bold">{t('home.title')}</h1>
  <p class="mt-2 text-[var(--c-text-soft)]">
    Software developer, curious reader, occasional filmmaker.
  </p>

</BaseLayout>
