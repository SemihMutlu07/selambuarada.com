---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchProjects } from '../../lib/github';

const { nodes: githubProjects } = await fetchProjects();

const maturityOrder = { thriving: 0, healthy: 1, dormant: 2, seedling: 3 };
const sorted = [...githubProjects].sort((a, b) => {
  const m = maturityOrder[a.maturity] - maturityOrder[b.maturity];
  if (m !== 0) return m;
  return b.stars - a.stars;
});
---

<BaseLayout title="Projeler" description="Geliştirdiğim ve yayınladığım yazılımlar.">

  <h1 class="text-2xl font-bold">Projeler</h1>

  {sorted.length === 0 ? (
    <p class="mt-6 text-[var(--c-text-faint)]">Henüz proje yok.</p>
  ) : (
    <ul class="mt-8 list-none p-0">
      {sorted.map((project, i) => (
        <li class:list={['border-t border-[var(--c-border)]', i === sorted.length - 1 && 'border-b']}>
          <a href={project.url} target="_blank" rel="noopener" class="block py-4 group">
            <div class="flex items-baseline justify-between gap-4">
              <span class="text-[var(--c-text)] group-hover:underline underline-offset-4">
                {project.name}
              </span>
              {project.language && (
                <span class="text-sm text-[var(--c-text-faint)] shrink-0">{project.language}</span>
              )}
            </div>
            {project.description && (
              <p class="mt-1 text-sm text-[var(--c-text-faint)]">{project.description}</p>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}

</BaseLayout>
