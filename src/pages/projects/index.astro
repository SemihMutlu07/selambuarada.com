---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchProjects } from '../../lib/github';

const { nodes: githubProjects } = await fetchProjects();
const projects = await getCollection('projects');

const maturityOrder = { thriving: 0, healthy: 1, dormant: 2, seedling: 3 };
const sorted = [...githubProjects].sort((a, b) => {
  const m = maturityOrder[a.maturity] - maturityOrder[b.maturity];
  if (m !== 0) return m;
  return b.stars - a.stars;
});
---

<BaseLayout title="Projeler" description="Geliştirdiğim ve yayınladığım yazılımlar.">
  <h1 class="text-3xl md:text-4xl font-bold text-[var(--c-text)]">
    Projeler
  </h1>
  <p class="mt-3 text-sm text-[var(--c-text-soft)]">
    Geliştirdiğim ve yayınladığım yazılımlar.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8 md:mt-10">
    {sorted.map((project) => (
      <a
        href={project.url}
        target="_blank"
        rel="noopener"
        class="block border border-[var(--c-border)] p-5 md:p-6 hover:border-[var(--c-accent)] transition-colors group"
      >
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="text-base font-semibold text-[var(--c-text)] group-hover:underline underline-offset-4">
            {project.name}
          </h2>
          {project.language && (
            <span class="flex items-center gap-1.5 shrink-0">
              <span class="w-2 h-2" style={`background: ${project.color}`}></span>
              <span class="text-xs text-[var(--c-text-faint)]">
                {project.language}
              </span>
            </span>
          )}
        </div>
        {project.description && (
          <p class="mt-2 text-sm text-[var(--c-text-soft)] leading-relaxed">
            {project.description}
          </p>
        )}
      </a>
    ))}
  </div>

  <noscript>
    {projects.length === 0 ? (
      <p class="mt-12 text-[var(--c-text-faint)]">Henüz proje yok.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-12">
        {projects.map((project) => (
          <div class="border border-[var(--c-border)] p-6">
            <h2 class="text-lg font-bold text-[var(--c-text)]">{project.data.title}</h2>
            <p class="mt-2 text-sm text-[var(--c-text-soft)]">{project.data.description}</p>
            <div class="flex flex-wrap gap-2 mt-4">
              {project.data.tech.map((item: string) => (
                <span class="text-xs border border-[var(--c-border)] px-2 py-1 text-[var(--c-text-faint)]">
                  {item}
                </span>
              ))}
            </div>
            <div class="flex gap-4 mt-4">
              {project.data.url && (
                <a href={project.data.url} target="_blank" rel="noopener" class="text-sm text-[var(--c-text-faint)] hover:underline underline-offset-4">
                  Ziyaret et
                </a>
              )}
              {project.data.github && (
                <a href={project.data.github} target="_blank" rel="noopener" class="text-sm text-[var(--c-text-faint)] hover:underline underline-offset-4">
                  GitHub
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </noscript>
</BaseLayout>
