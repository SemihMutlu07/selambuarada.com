---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchProjects } from '../../lib/github';

const { nodes: githubProjects } = await fetchProjects();
const projects = await getCollection('projects');

// Sort: thriving > healthy > dormant > seedling, then by stars
const maturityOrder = { thriving: 0, healthy: 1, dormant: 2, seedling: 3 };
const sorted = [...githubProjects].sort((a, b) => {
  const m = maturityOrder[a.maturity] - maturityOrder[b.maturity];
  if (m !== 0) return m;
  return b.stars - a.stars;
});
---

<BaseLayout title="Projects" description="Software I've built and shipped.">
  <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight text-black dark:text-white">
    Projects
  </h1>
  <p class="mt-3 md:mt-4 text-base text-[#666666] dark:text-[#666666]">
    Software I've built and shipped.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-10 md:mt-14">
    {sorted.map((project) => (
      <a
        href={project.url}
        target="_blank"
        rel="noopener"
        class="block border border-[#cccccc] dark:border-[#333333] p-5 md:p-6 hover:border-[#1a1a1a] dark:hover:border-[#999999] transition-colors group"
      >
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="font-mono text-[13px] tracking-[0.04em] text-black dark:text-white group-hover:underline underline-offset-4">
            {project.name}
          </h2>
          {project.language && (
            <span class="flex items-center gap-1.5 shrink-0">
              <span class="w-2 h-2 rounded-full" style={`background: ${project.color}`}></span>
              <span class="font-mono text-[12px] tracking-[0.06em] uppercase text-[#999999] dark:text-[#666666]">
                {project.language}
              </span>
            </span>
          )}
        </div>
        {project.description && (
          <p class="mt-2 text-base text-[#666666] dark:text-[#666666] leading-relaxed">
            {project.description}
          </p>
        )}
      </a>
    ))}
  </div>

  <noscript>
    {projects.length === 0 ? (
      <p class="mt-12 font-mono text-[13px] tracking-[0.08em] uppercase text-[#666666]">
        [ No projects yet ]
      </p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-12">
        {projects.map((project) => (
          <div class="border border-[#cccccc] dark:border-[#333333] p-6">
            <h2 class="text-lg font-bold text-black dark:text-white">{project.data.title}</h2>
            <p class="mt-2 text-base text-[#666666] dark:text-[#666666]">{project.data.description}</p>
            <div class="flex flex-wrap gap-2 mt-4">
              {project.data.tech.map((item: string) => (
                <span class="font-mono text-[12px] tracking-[0.06em] uppercase border border-[#cccccc] dark:border-[#333333] px-2 py-1 text-[#999999] dark:text-[#666666]">
                  {item}
                </span>
              ))}
            </div>
            <div class="flex gap-4 mt-4">
              {project.data.url && (
                <a href={project.data.url} target="_blank" rel="noopener" class="font-mono text-[12px] tracking-[0.06em] uppercase text-[#999999] dark:text-[#666666] hover:text-black dark:hover:text-white underline underline-offset-4 transition-colors">
                  Visit
                </a>
              )}
              {project.data.github && (
                <a href={project.data.github} target="_blank" rel="noopener" class="font-mono text-[12px] tracking-[0.06em] uppercase text-[#999999] dark:text-[#666666] hover:text-black dark:hover:text-white underline underline-offset-4 transition-colors">
                  GitHub
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </noscript>
</BaseLayout>
