---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchProjects } from '../../lib/github';

const { nodes: githubProjects } = await fetchProjects();

const maturityOrder = { thriving: 0, healthy: 1, dormant: 2, seedling: 3 };
const sorted = [...githubProjects].sort((a, b) => {
  const m = maturityOrder[a.maturity] - maturityOrder[b.maturity];
  if (m !== 0) return m;
  return b.stars - a.stars;
});
---

<BaseLayout title="Projeler" description="Geliştirdiğim ve yayınladığım yazılımlar.">
  <h1 class="text-3xl md:text-4xl font-bold text-[var(--c-text)]">
    Projeler
  </h1>
  <p class="mt-3 text-sm text-[var(--c-text-soft)]">
    Geliştirdiğim ve yayınladığım yazılımlar.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8 md:mt-10">
    {sorted.map((project) => (
      <a
        href={project.url}
        target="_blank"
        rel="noopener"
        class="block border border-[var(--c-border)] p-5 md:p-6 hover:border-[var(--c-accent)] transition-colors group"
      >
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="text-base font-semibold text-[var(--c-text)] group-hover:underline underline-offset-4">
            {project.name}
          </h2>
          {project.language && (
            <span class="flex items-center gap-1.5 shrink-0">
              <span class="w-2 h-2" style={`background: ${project.color}`}></span>
              <span class="text-xs text-[var(--c-text-faint)]">
                {project.language}
              </span>
            </span>
          )}
        </div>
        {project.description && (
          <p class="mt-2 text-sm text-[var(--c-text-soft)] leading-relaxed">
            {project.description}
          </p>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
