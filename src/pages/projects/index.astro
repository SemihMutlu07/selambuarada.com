---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchProjectGraph } from '../../lib/github';

const graph = await fetchProjectGraph();
const projects = await getCollection('projects');
---

<BaseLayout title="Projects" description="Software I've built and shipped.">
  <!-- Primary -->
  <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight text-black dark:text-white">
    Projects
  </h1>
  <p class="mt-3 md:mt-4 text-sm text-[#666666] dark:text-[#666666]">
    Software I've built and shipped.
  </p>

  <div id="mycelium-container" class="relative mt-8 md:mt-12 w-full border border-[#cccccc] dark:border-[#333333]" style="height: calc(100dvh - 14rem);min-height: 400px;">
    <p id="mycelium-loading" class="absolute inset-0 flex items-center justify-center font-mono text-[11px] tracking-[0.06em] uppercase text-[#666666] dark:text-[#666666]">
      [ Loading network... ]
    </p>
    <div
      id="project-tooltip"
      class="absolute z-10 hidden pointer-events-none px-3 py-2 border border-[#cccccc] dark:border-[#333333] bg-[#f5f5f5] dark:bg-[#111111] text-[#1a1a1a] dark:text-[#e8e8e8] font-mono text-[11px] tracking-[0.04em] max-w-xs"
    ></div>

    <!-- Settings drawer -->
    <div id="settings-drawer" class="absolute top-3 right-3 z-20">
      <button
        id="settings-toggle"
        class="w-8 h-8 flex items-center justify-center border border-[#cccccc] dark:border-[#333333] bg-[#f5f5f5] dark:bg-black text-[#999999] dark:text-[#666666] hover:text-black dark:hover:text-white transition-colors"
        aria-label="Toggle settings"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
        </svg>
      </button>
      <div id="settings-panel" class="hidden absolute top-10 right-0 w-44 border border-[#cccccc] dark:border-[#333333] bg-[#f5f5f5] dark:bg-[#111111] p-3 font-mono text-[11px] tracking-[0.06em]">
        <div class="uppercase text-black dark:text-white mb-3">Settings</div>
        <label class="flex items-center gap-2 cursor-pointer py-1 text-[#666666] dark:text-[#999999]">
          <input type="radio" name="colorMode" value="language" class="accent-[#5b9bf6]" checked />
          Color by language
        </label>
        <label class="flex items-center gap-2 cursor-pointer py-1 text-[#666666] dark:text-[#999999]">
          <input type="radio" name="colorMode" value="mono" class="accent-[#5b9bf6]" />
          Monochrome
        </label>
        <div class="border-t border-[#e8e8e8] dark:border-[#222222] my-2"></div>
        <label class="flex items-center gap-2 cursor-pointer py-1 text-[#666666] dark:text-[#999999]">
          <input type="checkbox" id="showLabels" class="accent-[#5b9bf6]" />
          Show labels
        </label>
      </div>
    </div>
  </div>

  <noscript>
    {projects.length === 0 ? (
      <p class="mt-12 font-mono text-[11px] tracking-[0.08em] uppercase text-[#666666]">
        [ No projects yet ]
      </p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-12">
        {projects.map((project) => (
          <div class="border border-[#cccccc] dark:border-[#333333] p-6">
            <h2 class="text-lg font-bold text-black dark:text-white">{project.data.title}</h2>
            <p class="mt-2 text-sm text-[#666666] dark:text-[#666666]">{project.data.description}</p>
            <div class="flex flex-wrap gap-2 mt-4">
              {project.data.tech.map((item: string) => (
                <span class="font-mono text-[10px] tracking-[0.06em] uppercase border border-[#cccccc] dark:border-[#333333] px-2 py-1 text-[#999999] dark:text-[#666666]">
                  {item}
                </span>
              ))}
            </div>
            <div class="flex gap-4 mt-4">
              {project.data.url && (
                <a href={project.data.url} target="_blank" rel="noopener" class="font-mono text-[10px] tracking-[0.06em] uppercase text-[#999999] dark:text-[#666666] hover:text-black dark:hover:text-white underline underline-offset-4 transition-colors">
                  Visit
                </a>
              )}
              {project.data.github && (
                <a href={project.data.github} target="_blank" rel="noopener" class="font-mono text-[10px] tracking-[0.06em] uppercase text-[#999999] dark:text-[#666666] hover:text-black dark:hover:text-white underline underline-offset-4 transition-colors">
                  GitHub
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </noscript>

  <script type="application/json" id="project-graph-data" set:html={JSON.stringify(graph)} />

  <script>
    import { initMycelium } from '../../lib/mycelium'
    import type { MyceliumSettings } from '../../lib/mycelium'

    const container = document.getElementById('mycelium-container')!
    const tooltip = document.getElementById('project-tooltip')!
    const dataEl = document.getElementById('project-graph-data')!
    const data = JSON.parse(dataEl.textContent!)

    const { dispose, updateSettings } = initMycelium(container, tooltip, data)
    document.getElementById('mycelium-loading')?.remove()

    // Settings drawer
    const toggle = document.getElementById('settings-toggle')!
    const panel = document.getElementById('settings-panel')!
    const colorRadios = document.querySelectorAll<HTMLInputElement>('input[name="colorMode"]')
    const labelsCheck = document.getElementById('showLabels') as HTMLInputElement

    // Load saved settings into UI
    const saved = JSON.parse(localStorage.getItem('mycelium-settings') || '{}')
    if (saved.colorMode === 'mono') {
      (document.querySelector('input[value="mono"]') as HTMLInputElement).checked = true
    }
    if (saved.showLabels) {
      labelsCheck.checked = true
    }

    toggle.addEventListener('click', (e) => {
      e.stopPropagation()
      panel.classList.toggle('hidden')
    })

    document.addEventListener('click', (e) => {
      if (!panel.contains(e.target as Node) && e.target !== toggle) {
        panel.classList.add('hidden')
      }
    })

    function getSettings(): MyceliumSettings {
      const colorMode = (document.querySelector('input[name="colorMode"]:checked') as HTMLInputElement)?.value as 'language' | 'mono'
      return { colorMode, showLabels: labelsCheck.checked }
    }

    colorRadios.forEach((r) => r.addEventListener('change', () => updateSettings(getSettings())))
    labelsCheck.addEventListener('change', () => updateSettings(getSettings()))

    document.addEventListener('astro:before-swap', () => dispose(), { once: true })
  </script>
</BaseLayout>
