---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, localePath } from '../../../i18n/utils';

const t = useTranslations('fr');

const films = await getCollection('films');
films.sort((a, b) => b.data.year - a.data.year);
---
<BaseLayout title={t('films.title')} description={t('films.description')}>

  <h1 class="text-2xl font-bold">{t('films.title')}</h1>

  {films.length === 0 ? (
    <p class="mt-6 text-[var(--c-text-faint)]">{t('films.empty')}</p>
  ) : (
    <ul class="mt-8 list-none p-0">
      {films.map((film, i) => (
        <li class:list={['border-t border-[var(--c-border)]', i === films.length - 1 && 'border-b']}>
          <a href={localePath('fr', `/films/${film.id}`)} class="block py-4 group">
            <div class="flex items-baseline justify-between gap-4">
              <span class="text-[var(--c-text)] group-hover:underline underline-offset-4">
                {film.data.title}
              </span>
              <span class="text-sm text-[var(--c-text-faint)] shrink-0">
                {film.data.year}
              </span>
            </div>
            <p class="mt-1 text-sm text-[var(--c-text-faint)]">{film.data.role}</p>
          </a>
        </li>
      ))}
    </ul>
  )}

</BaseLayout>
