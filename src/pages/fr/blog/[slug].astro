---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogImage from '../../../components/mdx/BlogImage.astro';
import SpotifyEmbed from '../../../components/mdx/SpotifyEmbed.astro';
import YouTubeEmbed from '../../../components/mdx/YouTubeEmbed.astro';
import { useTranslations, getDateLocale, localePath, getSlugFromId } from '../../../i18n/utils';
import { siteUrl } from '../../../lib/seo';
import type { Lang } from '../../../i18n/translations';

const lang: Lang = 'fr';
const t = useTranslations(lang);

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return data.lang === 'fr' && (import.meta.env.PROD ? !data.draft : true);
  });
  return posts.map(post => ({
    params: { slug: getSlugFromId(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const ogImage = post.data.og_image || '/og-image.png';
const metaDesc = post.data.meta_description || post.data.description;

const dateLocale = getDateLocale(lang);
function formatDate(date: Date): string {
  return date.toLocaleDateString(dateLocale, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const slug = getSlugFromId(post.id);
const canonicalUrl = new URL(localePath(lang, `/blog/${slug}`), siteUrl).toString();

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: metaDesc,
  inLanguage: lang,
  datePublished: post.data.date.toISOString(),
  mainEntityOfPage: canonicalUrl,
  author: { '@id': `${siteUrl}/#person` },
  publisher: { '@id': `${siteUrl}/#person` },
  image: new URL(ogImage, siteUrl).toString(),
});

const breadcrumbJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('home.title'), item: siteUrl },
    { '@type': 'ListItem', position: 2, name: t('blog.title'), item: `${siteUrl}${localePath(lang, '/blog')}` },
    { '@type': 'ListItem', position: 3, name: post.data.title },
  ],
});
---

<BaseLayout
  title={post.data.title}
  description={metaDesc}
  ogImage={ogImage}
  ogType="article"
>
  <script type="application/ld+json" set:html={jsonLd} />
  <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  <article>
    <time datetime={post.data.date.toISOString()} class="text-sm text-[var(--c-text-faint)]">
      {formatDate(post.data.date)}
    </time>

    <h1 class="mt-2 text-2xl font-bold">{post.data.title}</h1>

    <div class="mt-8 prose-nd">
      <Content components={{ BlogImage, SpotifyEmbed, YouTubeEmbed }} />
    </div>

    <div class="mt-8 pt-4 border-t border-[var(--c-border)]">
      <p class="text-sm text-[var(--c-text-faint)]">
        Par : <a href={localePath(lang, '/about')} class="hover:underline underline-offset-4">Semih Mutlu</a>
      </p>
    </div>

    <div class="mt-4 pt-4 border-t border-[var(--c-border)]">
      <a href={localePath(lang, '/blog')} class="text-sm text-[var(--c-text-faint)] hover:underline underline-offset-4">
        &larr; {t('blog.backLink')}
      </a>
    </div>
  </article>
</BaseLayout>
