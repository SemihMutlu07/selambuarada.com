---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const tagCounts = new Map<string, number>();
posts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  });
});
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags" description="All blog tags.">
  <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight">Tags</h1>
  {tags.length === 0 ? (
    <p class="mt-8 text-neutral-600 dark:text-neutral-400">No tags yet.</p>
  ) : (
    <ul class="mt-8 md:mt-12 space-y-3 md:space-y-4 list-none p-0">
      {tags.map(([tag, count]) => (
        <li>
          <a
            href={`/blog/tags/${tag}`}
            class="text-base md:text-lg font-bold uppercase hover:underline tracking-wide"
          >
            {tag} <span class="font-normal text-neutral-500 dark:text-neutral-400">({count})</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
