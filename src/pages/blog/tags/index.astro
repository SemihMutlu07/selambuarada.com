---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const tagCounts = new Map<string, number>();
posts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  });
});
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Etiketler" description="Tüm blog etiketleri.">

  <h1 class="text-3xl md:text-4xl font-bold text-[var(--c-text)]">
    Etiketler
  </h1>

  {tags.length === 0 ? (
    <p class="mt-12 text-[var(--c-text-faint)]">Henüz etiket yok.</p>
  ) : (
    <div class="mt-8 md:mt-10 flex flex-wrap gap-3">
      {tags.map(([tag, count]) => (
        <a
          href={`/blog/tags/${tag}`}
          class="flex items-center gap-2 px-4 py-2 border border-[var(--c-border)] text-sm text-[var(--c-text-soft)] hover:underline underline-offset-4"
        >
          <span>{tag}</span>
          <span class="text-xs text-[var(--c-text-faint)]">{count}</span>
        </a>
      ))}
    </div>
  )}

</BaseLayout>
