---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const tagCounts = new Map<string, number>();
posts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  });
});
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags" description="All blog tags.">

  <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight text-black dark:text-white">
    Tags
  </h1>

  {tags.length === 0 ? (
    <p class="mt-12 font-mono text-[11px] tracking-[0.08em] uppercase text-[#666666] dark:text-[#666666]">
      [ No tags yet ]
    </p>
  ) : (
    <ul class="mt-10 md:mt-14 list-none p-0">
      {tags.map(([tag, count], i) => (
        <li class:list={['border-t border-[#e8e8e8] dark:border-[#222222]', i === tags.length - 1 && 'border-b']}>
          <a
            href={`/blog/tags/${tag}`}
            class="flex items-baseline justify-between gap-4 py-4 group"
          >
            <span class="font-mono text-[11px] tracking-[0.08em] uppercase text-black dark:text-white group-hover:underline underline-offset-4">
              {tag}
            </span>
            <span class="font-mono text-[10px] tracking-[0.06em] uppercase text-[#999999] dark:text-[#666666] shrink-0">
              {count}
            </span>
          </a>
        </li>
      ))}
    </ul>
  )}

</BaseLayout>
