---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const uniqueTags = [...new Set(posts.flatMap(post => post.data.tags))];
  return uniqueTags.map(tag => ({
    params: { tag },
    props: { posts: posts.filter(p => p.data.tags.includes(tag)) },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
posts.sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('tr-TR', {
    year: 'numeric',
    month: 'short',
  });
}
---

<BaseLayout title={`${tag} etiketli yazılar`} description={`${tag} etiketli yazılar.`}>

  <a
    href="/blog/tags"
    class="text-sm text-[var(--c-text-faint)] hover:underline underline-offset-4"
  >
    &larr; Tüm etiketler
  </a>

  <h1 class="text-3xl md:text-4xl font-bold text-[var(--c-text)] mt-4">
    {tag}
  </h1>

  <ul class="mt-8 md:mt-10 list-none p-0">
    {posts.map((post: any, i: number) => (
      <li class:list={['border-t border-[var(--c-border)]', i === posts.length - 1 && 'border-b']}>
        <a href={`/blog/${post.id}`} class="block group py-5 md:py-6">
          <div class="flex items-baseline justify-between gap-4">
            <span class="text-base md:text-lg font-semibold text-[var(--c-text)] group-hover:underline underline-offset-4 leading-snug">
              {post.data.title}
            </span>
            <time
              datetime={post.data.date.toISOString()}
              class="text-sm text-[var(--c-text-faint)] shrink-0"
            >
              {formatDate(post.data.date)}
            </time>
          </div>
          {post.data.description && (
            <p class="mt-1.5 text-sm text-[var(--c-text-soft)] leading-relaxed">
              {post.data.description}
            </p>
          )}
        </a>
      </li>
    ))}
  </ul>

</BaseLayout>
