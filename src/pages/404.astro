---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Sayfa Bulunamadı" description="Aradığınız sayfa bulunamadı.">
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <h1 class="text-6xl font-bold text-[#1a1a1a]">404</h1>
    <p class="mt-4 text-lg text-[#666]">Aradığın sayfa bulunamadı.</p>
    <a
      href="/"
      class="mt-8 text-sm text-[#999] hover:text-[#1a1a1a] transition-colors underline underline-offset-4"
    >
      Ana sayfaya dön
    </a>
  </div>
</BaseLayout>
