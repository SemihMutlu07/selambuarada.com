---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const photosets = await getCollection('photosets');

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/photos/**/*.{jpg,jpeg,png,webp}',
  { eager: true }
);
---

<BaseLayout title="Fotoğraflar" description="Fotoğraf çalışmaları ve görsel işler.">

  <h1 class="text-3xl md:text-4xl font-bold text-[var(--c-text)]">
    Fotoğraflar
  </h1>

  {photosets.length === 0 ? (
    <p class="mt-12 text-[var(--c-text-faint)]">Henüz fotoğraf seti yok.</p>
  ) : (
    <div class="mt-8 md:mt-10">
      {photosets.map((set, i) => (
        <details class:list={['group border-t border-[var(--c-border)]', i === photosets.length - 1 && 'border-b']}>
          <summary class="flex items-baseline justify-between gap-4 py-5 cursor-pointer select-none list-none">
            <span class="text-base md:text-lg font-semibold text-[var(--c-text)] group-open:underline underline-offset-4">
              {set.data.title}
            </span>
            <span class="text-sm text-[var(--c-text-faint)] shrink-0">
              {set.data.images.length} fotoğraf
            </span>
          </summary>

          <div class="pb-6 md:pb-8">
            {set.data.description && (
              <p class="mb-5 text-sm text-[var(--c-text-soft)] leading-relaxed">
                {set.data.description}
              </p>
            )}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 md:gap-3">
              {set.data.images.map((img: { src: string; alt: string }) => {
                const mod = imageModules[img.src];
                return mod ? (
                  <Image
                    src={mod.default}
                    alt={img.alt}
                    class="w-full h-auto"
                    widths={[400, 800]}
                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  />
                ) : (
                  <p class="text-sm text-red-600">
                    Görsel bulunamadı: {img.src}
                  </p>
                );
              })}
            </div>
          </div>
        </details>
      ))}
    </div>
  )}

</BaseLayout>
