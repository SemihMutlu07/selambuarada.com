---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const films = await getCollection('films');
  return films.map(film => ({
    params: { id: film.id },
    props: { film },
  }));
}

const { film } = Astro.props;
const { title, year, role, embedUrl, description, credits, bts } = film.data;
---
<BaseLayout title={title} description={description}>

  <a
    href="/films"
    class="text-sm text-[var(--c-text-faint)] hover:underline underline-offset-4"
  >
    &larr; Tüm filmler
  </a>

  <div class="flex items-center gap-3 mt-4 mb-4">
    <span class="text-sm text-[var(--c-text-faint)]">{year}</span>
    <span class="text-[var(--c-border)]">&middot;</span>
    <span class="text-sm text-[var(--c-text-faint)]">{role}</span>
  </div>

  <h1 class="text-2xl font-bold">{title}</h1>

  <div class="mt-8 md:mt-10 aspect-video w-full border border-[var(--c-border)]">
    <iframe
      src={embedUrl}
      class="w-full h-full"
      allowfullscreen
      loading="lazy"
      title={title}
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    ></iframe>
  </div>

  <section class="mt-10 md:mt-12 max-w-2xl">
    <h2 class="text-lg font-bold text-[var(--c-text)] mb-3">Hakkında</h2>
    <p class="text-base leading-relaxed text-[var(--c-text-soft)]">{description}</p>
  </section>

  <section class="mt-10 md:mt-12">
    <h2 class="text-lg font-bold text-[var(--c-text)] mb-4">Ekip</h2>
    <dl class="space-y-0">
      {credits.map((c: { role: string; name: string }, i: number) => (
        <div class:list={['flex gap-6 py-3 border-t border-[var(--c-border)]', i === credits.length - 1 && 'border-b']}>
          <dt class="text-sm text-[var(--c-text-faint)] min-w-[120px] shrink-0 pt-px">
            {c.role}
          </dt>
          <dd class="text-base text-[var(--c-text)]">{c.name}</dd>
        </div>
      ))}
    </dl>
  </section>

  {bts && (
    <section class="mt-10 md:mt-12 max-w-2xl">
      <h2 class="text-lg font-bold text-[var(--c-text)] mb-3">Kamera Arkası</h2>
      <p class="text-base leading-relaxed text-[var(--c-text-soft)]">{bts}</p>
    </section>
  )}

</BaseLayout>
