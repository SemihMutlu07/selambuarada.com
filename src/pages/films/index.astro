---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const films = await getCollection('films');
films.sort((a, b) => b.data.year - a.data.year);
---
<BaseLayout title="Filmler" description="Kısa filmler ve video çalışmaları.">

  <h1 class="text-3xl md:text-4xl font-bold text-[#1a1a1a]">
    Filmler
  </h1>

  {films.length === 0 ? (
    <p class="mt-12 text-[#999]">Henüz film yok.</p>
  ) : (
    <ul class="mt-8 md:mt-10 list-none p-0">
      {films.map((film, i) => (
        <li class:list={['border-t border-[#e0e0e0]', i === films.length - 1 && 'border-b']}>
          <a href={`/films/${film.id}`} class="block group py-5 md:py-6">
            <div class="flex items-baseline justify-between gap-4">
              <span class="text-base md:text-lg font-semibold text-[#1a1a1a] group-hover:underline underline-offset-4 font-serif">
                {film.data.title}
              </span>
              <span class="text-sm text-[#999] shrink-0">
                {film.data.year}
              </span>
            </div>
            <p class="mt-1 text-sm text-[#666]">
              {film.data.role}
            </p>
          </a>
        </li>
      ))}
    </ul>
  )}

</BaseLayout>
