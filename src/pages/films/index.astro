---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const films = await getCollection('films');
films.sort((a, b) => b.data.year - a.data.year);
---
<BaseLayout title="Films" description="Short films and video work.">
  <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight">Films</h1>
  <p class="mt-3 md:mt-4 text-base md:text-lg text-neutral-600 dark:text-neutral-400">Short films and video work.</p>

  {films.length === 0 ? (
    <p class="mt-8 md:mt-12 text-neutral-500">No films yet.</p>
  ) : (
    <ul class="space-y-4 md:space-y-6 mt-8 md:mt-12">
      {films.map(film => (
        <li>
          <a href={`/films/${film.id}`} class="group block">
            <span class="text-xl md:text-2xl font-bold group-hover:underline">{film.data.title}</span>
            <span class="ml-2 md:ml-3 text-sm md:text-base text-neutral-500">{film.data.year}</span>
            <p class="mt-1 text-xs md:text-sm uppercase tracking-wider text-neutral-600 dark:text-neutral-400">{film.data.role}</p>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
